# Supabase (required for auth and profiles)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Use either the legacy JWT anon key (eyJ...) OR the new publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key-here

# Server-only: required for marking invite codes as used after signup
# Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server-only: password gate for /admin/* pages (invite codes, users, QR maker)
# When set, visiting /admin/* shows a password form — no Supabase login or is_admin required.
# Also accepts logged-in users with profiles.is_admin = true.
ADMIN_PAGE_PASSWORD=choose-a-strong-admin-password

# Public site URL (required for production / Vercel)
# Used for email auth redirects, public profile links, and metadata.
# Local dev: http://localhost:3000
# Production: https://your-domain.vercel.app (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only: username of the admin profile whose public "1:1 상담" link is used on
# privacy/terms/forgot-password pages. Defaults to hyun1016 when unset.
# QRIT_ADMIN_USERNAME=hyun1016

# --- Local development ---
# Copy this file to .env.local and fill in real values, then restart: npm run dev
#
# --- Vercel production ---
# .env.local is NOT deployed. Add the same NEXT_PUBLIC_* variables in:
# Vercel Dashboard → Project → Settings → Environment Variables (Production + Preview)
# Then redeploy — NEXT_PUBLIC_* values are embedded at build time.
#
# After setting env vars, run these in Supabase SQL Editor (in order):
# 1. supabase/migrations/001_initial.sql
# 2. supabase/migrations/002 through 025 (or run 009_signup_trigger_fix.sql once)
# 3. Authentication → Providers → Email → disable "Confirm email" (required for phone login)
# 4. Authentication → URL Configuration:
#    - Site URL: match NEXT_PUBLIC_SITE_URL
#    - Redirect URL: {NEXT_PUBLIC_SITE_URL}/auth/callback
#
# Password reset (/forgot-password) uses phone + username verification with rate limiting.
# Requires SUPABASE_SERVICE_ROLE_KEY and migration 025_password_reset.sql.
# Kakao admin chat remains fallback when username is unknown.
